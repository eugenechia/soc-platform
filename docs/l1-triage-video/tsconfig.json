{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@motion-canvas/2d/lib",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["@motion-canvas/core"]
  },
  "include": ["src"]
}
