# soc-platform environment configuration.
#
# Local dev: copy to .env, fill in values.
# Azure prod: secrets come from Key Vault (see AZURE_KEYVAULT_URL below).
# If AZURE_KEYVAULT_URL is set, values below are overridden by KV lookups
# for any name not present in env. See tools/secrets.py.

# ── Flask ────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=         # generate: python3 -c "import secrets; print(secrets.token_hex(32))"
PORT=5060
WEB_CONCURRENCY=1         # DO NOT change. APScheduler requires single worker.
DB_PATH=                  # Azure: set to /tmp/soc_platform.db (SQLite locks fail over Azure Files SMB). Local: leave blank (defaults to data/soc_platform.db)

# ── Entra ID (user SSO) ──────────────────────────────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=              # secret: KV in Azure
ENTRA_REDIRECT_URI=http://localhost:5060/auth/callback
ENTRA_ALLOWED_GROUP_ID=           # Azure AD security group GUID

# ── LLM (Reports mode — narrative generation) ───────────────────────
# tools/llm_client.py picks the provider in this order, first match wins.
# Set ONE block; leave the others blank.
#
#   1) OpenAI-compatible (Ollama, vLLM, any /v1 chat endpoint)
#      — used by Cisco-OCP and any on-prem deployment
OPENAI_COMPAT_BASE_URL=           # e.g. http://ollama:11434/v1
OPENAI_COMPAT_API_KEY=            # blank → "no-key-needed" (Ollama)
OPENAI_COMPAT_MODEL=              # e.g. qwen2.5:32b
#
#   2) Azure OpenAI (SOC-Platform on ACA)
AZURE_OPENAI_ENDPOINT=            # https://<resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=          # deployment name, e.g. gpt-5.2
AZURE_OPENAI_API_VERSION=2024-10-21
#
#   3) Public OpenAI (developer / CI fallback)
OPENAI_API_KEY=                   # secret: KV in Azure
OPENAI_MODEL=                     # e.g. gpt-5.2

# ── LLM (Investigate mode — interactive analyst) ────────────────────
# Investigate mode uses the OpenAI Responses API with SOCRadar MCP tools
# (see routes/investigate.py). Cisco-OCP has its own Ollama-based
# investigate route (different protocol, not part of this factory).
INVESTIGATE_MODEL=gpt-5.2

# ── Key Vault (prod only) ────────────────────────────────────────────
AZURE_KEYVAULT_URL=               # https://<your-kv>.vault.azure.net — leave blank in dev

# ── Jira (scheduled reports) ─────────────────────────────────────────
JIRA_URL=https://logicalisasia.atlassian.net
JIRA_EMAIL=                       # service account
JIRA_API_TOKEN=                   # secret: KV in Azure
USE_SAMPLE_DATA=true              # true → uses samples/sample-CAM Jira Dump.csv

# ── Splunk (scheduled reports) ───────────────────────────────────────
SPLUNK_HOST=
SPLUNK_TOKEN=                     # secret: KV in Azure
SPLUNK_VERIFY_SSL=true

# ── Sentinel (scheduled reports) ─────────────────────────────────────
# Sentinel credentials are now per-customer, not global. Each customer record
# in data/customers.json carries:
#   sentinel_tenant_id, sentinel_client_id, sentinel_workspace_id,
#   sentinel_client_secret_kv_name (the actual secret value lives in KV).
# Configured via the Manage Customers admin UI; AZURE_KEYVAULT_URL above must be
# set so the platform can read/write the per-customer secrets.

# ── SOCRadar — REST (scheduled reports + L1 Triage IOC enrichment) ───
# Each SOCRadar product has its own API key. Names below match SOCRadar's
# customer-portal labels exactly so colleagues can find the right key.
SOCRADAR_COMPANY_ID=                          # non-secret (e.g. 56260)

# Currently wired:
SOCRADAR_THREAT_ANALYSIS_KEY=                 # secret: KV. /threat/analysis (L1 Triage IOC reputation)
SOCRADAR_COMPANY_KEY=                         # secret: KV. /company/{id}/incidents/v4 (alarms feed)
SOCRADAR_IDENTITY_INTELLIGENCE_KEY=           # secret: KV. /company/{id}/dark-web-monitoring/{sub}/v2

# Staged for future wiring — endpoint paths pending SOCRadar support confirmation.
# Setting these now means re-deploy is unnecessary once paths are known; just
# code change.
SOCRADAR_THREAT_ACTOR_KEY=                    # secret: KV. for /threat-actors/* (TBD)
SOCRADAR_CTI_VULNERABILITY_KEY=               # secret: KV. for CVE intel feed (TBD)
SOCRADAR_THREAT_FEED_KEY=                     # secret: KV. for threat-feed IOC enrichment (TBD)

# Legacy alias — read by tools/socradar_rest.py as a fallback for SOCRADAR_COMPANY_KEY
# so a deploy with only the old name keeps working through one rev cycle. Remove
# once all environments have SOCRADAR_COMPANY_KEY set.
SOCRADAR_IOC_ENRICHMENT_KEY=                  # DEPRECATED: alias for SOCRADAR_COMPANY_KEY

# ── SOCRadar — MCP (interactive Investigate mode) ────────────────────
SOCRADAR_MCP_URL=https://mcp.socradar.com
SOCRADAR_REDIRECT_URI=http://localhost:5060/investigate/oauth/callback

# ── Tavily (Investigate mode web search) ─────────────────────────────
TAVILY_API_KEY=                   # secret: KV in Azure

# ── SMTP (scheduled report delivery) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=                        # secret: KV in Azure
SMTP_FROM=

# ── IOC Enrichment (Jira webhook → reputation check → auto-triage) ────
# Jira webhook URL: https://<soc-platform-url>/webhook/jira?secret=<JIRA_WEBHOOK_SECRET>
# Configure in Jira → System → Webhooks → Create webhook (Event: Issue Created)
JIRA_WEBHOOK_SECRET=              # token added to webhook URL for validation
JIRA_ENRICHMENT_PROJECT=          # Jira project keys, comma-separated (e.g. SCDM,LOGICALIS). Blank = all.
JIRA_GSOC_ACCOUNT_ID=             # Jira account ID for GSOC service account (auto-assign on ticket arrival). Empty = skip.
JIRA_L1_ACCOUNT_ID=               # Jira account ID for L1 lead (True-Positive verdict). Empty = skip assignment.
JIRA_L2_ACCOUNT_ID=               # Jira account ID for L2 reviewer (False-Positive / Unknown verdict). Empty = skip assignment.
MALICIOUS_SCORE_THRESHOLD=70      # SOCRadar score cutoff for malicious verdict (0-100)

# Verdict-driven Jira labels (Phase 1 of L1 Triage redesign, 2026-06-08).
# All three labels MUST already exist in the target Jira instance — the webhook
# handler only ADDS the label, it does not create it. Override the defaults
# below if your Jira convention differs.
JIRA_TRIAGE_MALICIOUS_LABEL=True-Positive
JIRA_TRIAGE_CLEAN_LABEL=False-Positive
JIRA_TRIAGE_UNKNOWN_LABEL=Unknown

# Webhook background poll loop. The thread polls the Jira API every
# WEBHOOK_FETCH_DELAY_SECONDS, breaking early once any entity custom field is
# populated (or after WEBHOOK_FETCH_MAX_WAIT_SECONDS total elapses).
# Service Desk request forms can take 30+ seconds to merge entity fields after
# issue_created fires; programmatically-created tickets populate immediately.
WEBHOOK_FETCH_DELAY_SECONDS=5          # interval between Jira API polls
WEBHOOK_FETCH_MAX_WAIT_SECONDS=60      # total polling timeout
WEBHOOK_FETCH_STABILIZATION_SECONDS=30 # extra sleep after first detection to catch later waves

# Sentinel-style structured entity custom field IDs. Defaults match the SCDM
# project (verified 2026-05-05). Override only if Jira admin renumbers fields.
JIRA_FIELD_IP_ENTITIES=customfield_10079    # IP Address Entities (ADF)
JIRA_FIELD_HOST_ENTITIES=customfield_10078  # Host Entities (ADF)
JIRA_FIELD_DNS_ENTITIES=customfield_10080   # DNS Entities (ADF)
JIRA_FIELD_URL_ENTITIES=customfield_10081   # URL Entities (ADF)
JIRA_FIELD_HASH_ENTITIES=customfield_10082  # FileHash Entities (ADF)

# ── VirusTotal (IOC enrichment — optional) ────────────────────────────
VT_API_KEY=                       # Leave blank until key is available

# ── AbuseIPDB (IP reputation — optional) ─────────────────────────────
ABUSEIPDB_API_KEY=                # Leave blank until key is available

# ── SIEM Ticket Gateway (POST /api/ingest) ───────────────────────────
# Receives normalized SIEM alerts (Splunk/Sentinel) and dedups them by
# SHA-256 of "siem:rule_id|primary_entity". Either creates a new Jira
# ticket or appends to an existing one. SIEMs authenticate by sending
# X-Shared-Secret header matching GATEWAY_SHARED_SECRET.
GATEWAY_SHARED_SECRET=            # secret: KV in Azure (kv name: gateway-shared-secret)
JIRA_PROJECT_KEY=SCDM             # Project the gateway writes tickets to
JIRA_ISSUE_TYPE=[System] Incident # Issue type name (must exist in JIRA_PROJECT_KEY)

# Custom field IDs for the gateway's metadata fields. Different from the L1
# Triage entity fields above. Defaults match SCDM as of 2026-05-05.
JIRA_FIELD_SOURCE_SIEM=customfield_11588        # Incident Source (single-select: Splunk/Sentinel/...)
JIRA_FIELD_SOURCE_ALERT_ID=customfield_10125    # Customer SIEM Incident (short text — dedup key)
JIRA_FIELD_SEVERITY=customfield_10038           # Severity (single-select: Sev-0/.../Sev-3 in SCDM)
JIRA_FIELD_ENTITIES=customfield_10074           # Entities (textarea/ADF)
JIRA_FIELD_RAW_LINK=customfield_10073           # Incident URL (textarea/ADF — link back to SIEM event)
JIRA_FIELD_OCCURRENCE_COUNT=customfield_11589   # Occurrence Count (number)
JIRA_FIELD_LAST_SEEN=customfield_11590          # Last Seen (datetime)

# ── Webhook-side dedup (catches Sentinel-Logic-App-created tickets) ──
# When set to "true" (default), the Jira webhook handler performs dedup on
# tickets that were created OUTSIDE /api/ingest — primarily Sentinel's Logic
# App, which writes tickets directly via Jira REST. The handler derives a key
# from "Incident ID"/"Alert ID" in the description, writes it to
# JIRA_FIELD_SOURCE_ALERT_ID, then searches for an OLDER open ticket within
# 24h that strictly matches: same summary + same five typed entity fields.
# On strict match, the duplicate is AUTO-CLOSED via the SCDM workflow's native
# "Resolution Category = Duplicate" marker; its summary is prefixed; the
# Potential-TP label (if any) is removed and a system label added. The
# original's occurrence count is bumped. L1 Triage is skipped on the
# duplicate (no point enriching a ticket that's auto-closing).
DEDUP_WEBHOOK_ENABLED=true

# Tag prepended to the duplicate ticket's summary so analysts spot duplicates
# at a glance in any list view.
JIRA_DUPLICATE_SUMMARY_PREFIX=[DUPLICATE]

# Transition ID for the Closed-with-resolution path. Default matches SCDM
# (transition 181). The transition's validators in SCDM require the three
# custom fields below to be filled before it succeeds.
JIRA_CLOSE_TRANSITION_ID=181

# Custom field IDs on the Close screen. Defaults match SCDM as of 2026-05-06.
JIRA_FIELD_CLOSE_JUSTIFICATION=customfield_10057   # single-select
JIRA_FIELD_RESOLUTION_SUMMARY=customfield_10127    # textarea/ADF
JIRA_FIELD_RESOLUTION_CATEGORY=customfield_10521   # single-select

# Values written to the above fields when auto-closing a duplicate.
# Close Justification options in SCDM: False/True/Benign Positive,
# False/True Negative, Other Comments. "Other Comments" is the safest neutral
# default for an unreviewed auto-closed duplicate.
JIRA_CLOSE_JUSTIFICATION_VALUE=Other Comments
# Resolution Category options in SCDM: Duplicate, Escalated, Known Issue, Misrouted.
JIRA_RESOLUTION_CATEGORY_VALUE=Duplicate

# Label policy on close.
# Duplicates: inherit the original ticket's labels exactly (no system marker
# added — see SOC SOP 2026-05-06). If the original is unlabelled, the close
# transition uses a generic `auto-closed` fallback so the validator passes.
# Tuning suppression (separate flow): strip the malicious label and add the
# `auto-suppressed-tuning` system marker. The malicious-label name lives in
# JIRA_LABEL_REMOVE_ON_CLOSE — keep this in sync with JIRA_TRIAGE_MALICIOUS_LABEL.
JIRA_LABEL_REMOVE_ON_CLOSE=True-Positive
